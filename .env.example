# Copy to .env (which is gitignored) and fill in your key.
#
# SerpAPI free tier: 100 searches/month, no credit card required.
# Sign up at https://serpapi.com — your key lives at
# https://serpapi.com/manage-api-key
#
# Leave blank or unset to run in Suggest-only mode (free, no auth).
SERPAPI_KEY=

# Optional: override the default SQLite path (default is ./seoserper.db).
# SEOSERPER_DB=/absolute/path/to/seoserper.db
